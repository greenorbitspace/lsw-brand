---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/PageHero.astro';
---
<BaseLayout title="Typography — Leicester Space Week brand"><PageHero eyebrow="Typography" title="Technical. Human. Clear." intro="A two-typeface system balances a geometric headline voice with highly readable information design." /><section class="section"><div class="shell"><div class="type-stage"><p class="eyebrow">Headlines / Space Grotesk</p><p class="specimen">Look up.</p><div class="type-info"><div><h3>Space Grotesk</h3><p>Use Medium, Semibold and Bold for headlines, navigation, labels and event names.</p></div><div><h3>Set it with space</h3><p>Use confident scale, compact tracking and short, declarative line breaks. Avoid all-cap paragraphs.</p></div></div></div></div></section><section class="section" style="background:#fff"><div class="shell"><div class="section-head"><p class="eyebrow">Body / Inter</p><h2>Designed for information.</h2><p>Inter supports the system with a neutral, highly legible voice across web, programmes, captions and practical event communications.</p></div><div class="cards"><article class="card"><span class="glyph">64</span><div><h3>Display</h3><p>Space Grotesk Bold. Reserved for campaign moments and page titles.</p></div></article><article class="card"><span class="glyph">32</span><div><h3>Heading</h3><p>Space Grotesk Semibold. Use to group clear sections of information.</p></div></article><article class="card"><span class="glyph">18</span><div><h3>Body</h3><p>Inter Regular. Default size for comfortable digital reading.</p></div></article></div></div></section></BaseLayout>
